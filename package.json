{
  "name": "@soupler-hq/orbit",
  "version": "2.4.0",
  "description": "Production-grade Orbit framework — design, build, deploy, and monitor any kind of work",
  "main": "bin/install.js",
  "bin": {
    "orbit": "bin/install.js"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "scripts": {
    "install-local": "bash install.sh --local --tool claude",
    "install-global": "bash install.sh --global --tool claude",
    "install-all": "bash install.sh --global --all",
    "nexus-init": "node bin/install.js nexus init",
    "nexus-sync": "node bin/install.js nexus sync",
    "validate": "bash bin/validate.sh",
    "eval": "bash bin/eval.sh",
    "lint": "eslint bin/",
    "lint:fix": "eslint bin/ --fix",
    "format:check": "prettier --check bin/",
    "format:write": "prettier --write bin/"
  },
  "keywords": [
    "ai-agents",
    "claude",
    "claude-code",
    "llm",
    "orchestration",
    "agentic",
    "skills",
    "tdd",
    "devops",
    "automation"
  ],
  "author": "Soupler Engineering",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/soupler-hq/orbit"
  },
  "bugs": {
    "url": "https://github.com/soupler-hq/orbit/issues"
  },
  "homepage": "https://github.com/soupler-hq/orbit#readme",
  "files": [
    "CLAUDE.md",
    "AGENTS.md",
    "README.md",
    "INSTRUCTIONS.md",
    "SKILLS.md",
    "WORKFLOWS.md",
    "orbit.registry.json",
    "orbit.config.schema.json",
    "install.sh",
    "agents/",
    "skills/",
    "commands/",
    "state/",
    "hooks/",
    "forge/",
    "docs/",
    "docs/runtime-adapters.md",
    "docs/evals.md",
    "bin/",
    "bin/eval.sh"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1"
  }
}
