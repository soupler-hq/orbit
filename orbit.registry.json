  "workflows": [
    {
      "name": "discover",
      "command": "/orbit:discover",
      "mode": "collaborative",
      "agents": [
        "researcher",
        "designer"
      ],
      "inputs": [
        "problem statement",
        "target user hypothesis"
      ],
      "outputs": [
        "DISCOVERY.md"
      ]
    },
    {
      "name": "new-project",
      "command": "/orbit:new-project",
      "mode": "collaborative",
      "inputs": [
        "scope",
        "users",
        "constraints",
        "existing systems"
      ],
      "outputs": [
        "PROJECT.md",
        "REQUIREMENTS.md",
        "ROADMAP.md",
        "STATE.md"
      ]
    },
    {
      "name": "plan",
      "command": "/orbit:plan",
      "mode": "collaborative",
      "inputs": [
        "STATE.md",
        "ROADMAP.md",
        "REQUIREMENTS.md"
      ],
      "outputs": [
        "PHASE-{N}-PLAN.md"
      ]
    },
    {
      "name": "build",
      "command": "/orbit:build",
      "mode": "autonomous",
      "inputs": [
        "PHASE-{N}-PLAN.md",
        "ARCH.md",
        "STATE.md"
      ],
      "outputs": [
        "task outputs",
        "SUMMARY.md",
        "PHASE-{N}-VERIFICATION.md"
      ]
    },
    {
      "name": "verify",
      "command": "/orbit:verify",
      "mode": "audit",
      "inputs": [
        "PHASE-{N}-PLAN.md",
        "build outputs"
      ],
      "outputs": [
        "PHASE-{N}-UAT.md"
      ]
    },
    {
      "name": "ship",
      "command": "/orbit:ship",
      "mode": "audit",
      "inputs": [
        "PHASE-{N}-UAT.md",
        "review output"
      ],
      "outputs": [
        "release summary",
        "STATE.md update"
      ]
    },
    {
      "name": "launch",
      "command": "/orbit:launch",
      "mode": "collaborative",
      "agents": [
        "launch-planner",
        "technical-writer"
      ],
      "inputs": [
        "release artifacts",
        "target audience",
        "launch channels"
      ],
      "outputs": [
        "LAUNCH-PLAN.md",
        "GTM-CHECKLIST.md",
        "ANNOUNCEMENT-DRAFT.md"
      ]
    },
    {
      "name": "quick",
      "command": "/orbit:quick",
      "mode": "collaborative",
      "inputs": [
        "task description"
      ],
      "outputs": [
        "focused task result",
        "verification",
        "state update"
      ]
    },
    {
      "name": "forge",
      "command": "/orbit:forge",
      "mode": "collaborative",
      "inputs": [
        "task description"
      ],
      "outputs": [
        "new agent file",
        "registry update"
      ]
    },
    {
      "name": "review",
      "command": "/orbit:review",
      "mode": "audit",
      "inputs": [
        "changed files",
        "ARCH.md",
        "REQUIREMENTS.md"
      ],
      "outputs": [
        "review report"
      ]
    },
    {
      "name": "audit",
      "command": "/orbit:audit",
      "mode": "audit",
      "inputs": [
        "changed files",
        "dependency graph"
      ],
      "outputs": [
        "security audit report"
      ]
    },
    {
      "name": "eval",
      "command": "/orbit:eval",
      "mode": "audit",
      "agents": [
        "reviewer"
      ],
      "inputs": [
        "README.md",
        "registry",
        "runtime adapters",
        "workflow docs"
      ],
      "outputs": [
        "EVAL-REPORT.md",
        "eval-report.json"
      ]
    },
    {
      "name": "resume",
      "command": "/orbit:resume",
      "mode": "collaborative",
      "inputs": [
        "STATE.md",
        "pre-compact snapshot",
        "git log"
      ],
      "outputs": [
        "reconstructed context"
      ]
    },
    {
      "name": "next",
      "command": "/orbit:next",
      "mode": "collaborative",
      "inputs": [
        "STATE.md",
        "ROADMAP.md"
      ],
      "outputs": [
        "next action"
      ]
    },
    {
      "name": "progress",
      "command": "/orbit:progress",
      "mode": "audit",
      "inputs": [
        "STATE.md",
        "ROADMAP.md"
      ],
      "outputs": [
        "project status summary"
      ]
    },
    {
      "name": "map-codebase",
      "command": "/orbit:map-codebase",
      "mode": "audit",
      "inputs": [
        "repo tree",
        "source files",
        "STATE.md"
      ],
