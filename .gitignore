# Orbit Ignore
.orbit/state/*
!.orbit/state/.gitkeep
.orbit/hooks/*
!.orbit/hooks/.gitkeep
.orbit/errors/
.orbit/state/sessions.log
.orbit/state/tool-usage.log
.orbit/state/compact.log

# Git Worktrees
.worktrees/

# Test coverage output (generated by vitest --coverage)
coverage/

# OS/Node
node_modules/
.DS_Store
*.log
.orbit.lock

# Generated at release time — not source
RELEASE_NOTES.md

# Coding agent install artifacts — machine-specific, generated by install.sh
# Never commit these. Run `bash install.sh --local --tool <name>` to regenerate.
.claude/
.codex/
.cursor/
.windsurf/

# AGENTS.md — eliminated in v2.8.0, replaced by generated CLAUDE.md/INSTRUCTIONS.md
# Guard against accidental re-creation by old installers or manual copies
AGENTS.md
