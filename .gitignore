# Orbit Ignore
.orbit/state/*
!.orbit/state/.gitkeep
.orbit/hooks/*
!.orbit/hooks/.gitkeep

# Git Worktrees
.worktrees/

# Local Claude Code settings (machine-specific, may contain local paths)
.claude/settings.local.json

# Test coverage output (generated by vitest --coverage)
coverage/

# OS/Node
node_modules/
.DS_Store
*.log
.orbit.lock

# Generated
coverage/

# Local IDE
.claude/settings.local.json
RELEASE_NOTES.md

# Local Orbit install artifacts (machine-specific, not part of the published framework)
# settings.json is tracked explicitly; everything else under .claude/ is local
.claude/*
!.claude/settings.json

# AGENTS.md — eliminated in v2.8.0, replaced by generated CLAUDE.md/INSTRUCTIONS.md
# Guard against accidental re-creation by old installers or manual copies
AGENTS.md

# Orbit
.orbit/errors/
.orbit/state/sessions.log
.orbit/state/tool-usage.log
.orbit/state/compact.log
.worktrees/
